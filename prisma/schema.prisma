generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id               String    @id @default(cuid())
  firstName        String
  lastName         String
  fullName         String
  email            String    @unique
  phone            String?
  businessName     String?
  roleOrIndustry   String?
  instagram        String?
  linkedin         String?
  website          String?
  city             String?
  contactSource    String?
  consentToEmail   Boolean   @default(false)
  unsubscribed     Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastRsvpAt       DateTime?
  lastSurveyAt     DateTime?

  rsvps            Rsvp[]
  emailLogs        EmailLog[]
  surveyResponses  SurveyResponse[]
  notes            ContactNote[]
  tags             ContactTag[]
  opportunities    Opportunity[]

  @@map("contacts")
}

model Event {
  id                String    @id @default(cuid())
  eventName         String
  eventSlug         String    @unique
  eventDate         DateTime
  startTime         String
  endTime           String
  locationName      String
  address           String
  description       String?
  rsvpLink          String?
  surveyLink        String?
  facebookEventLink String?
  status            String    @default("draft")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  rsvps             Rsvp[]
  emailLogs         EmailLog[]
  surveyResponses   SurveyResponse[]
  opportunities     Opportunity[]

  @@map("events")
}

model Rsvp {
  id              String    @id @default(cuid())
  contactId       String
  eventId         String
  rsvpStatus      String    @default("confirmed")
  numberOfGuests  Int       @default(1)
  howDidYouHear   String?
  checkedIn       Boolean   @default(false)
  attended        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contact         Contact   @relation(fields: [contactId], references: [id])
  event           Event     @relation(fields: [eventId], references: [id])

  @@unique([contactId, eventId])
  @@map("rsvps")
}

model SurveyResponse {
  id                String    @id @default(cuid())
  contactId         String
  eventId           String?
  surveyTitle       String
  answersJson       Json
  rating            Int?
  interestTags      String[]
  keyFeedback       String?
  suggestedFollowUp String?
  submittedAt       DateTime  @default(now())

  contact           Contact   @relation(fields: [contactId], references: [id])
  event             Event?    @relation(fields: [eventId], references: [id])

  @@map("survey_responses")
}

model EmailLog {
  id            String    @id @default(cuid())
  contactId     String
  eventId       String?
  emailType     String
  subject       String
  status        String    @default("sent")
  sentAt        DateTime  @default(now())
  openedAt      DateTime?
  clickedAt     DateTime?
  errorMessage  String?

  contact       Contact   @relation(fields: [contactId], references: [id])
  event         Event?    @relation(fields: [eventId], references: [id])

  @@map("email_logs")
}

model ContactNote {
  id          String   @id @default(cuid())
  contactId   String
  note        String
  createdBy   String
  createdAt   DateTime @default(now())

  contact     Contact  @relation(fields: [contactId], references: [id])

  @@map("contact_notes")
}

model ContactTag {
  id        String  @id @default(cuid())
  contactId String
  tag       String

  contact   Contact @relation(fields: [contactId], references: [id])

  @@unique([contactId, tag])
  @@map("contact_tags")
}

model Opportunity {
  id              String    @id @default(cuid())
  contactId       String
  eventId         String?
  opportunityType String
  status          String    @default("potential")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contact         Contact   @relation(fields: [contactId], references: [id])
  event           Event?    @relation(fields: [eventId], references: [id])

  @@map("opportunities")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  @@map("admin_users")
}

model EmailCampaign {
  id          String    @id @default(cuid())
  name        String
  subject     String
  bodyHtml    String
  audienceTag String?
  eventId     String?
  status      String    @default("draft")
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("email_campaigns")
}
