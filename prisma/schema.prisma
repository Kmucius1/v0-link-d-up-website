generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id               String    @id @default(cuid())
  firstName        String
  lastName         String
  fullName         String
  email            String    @unique
  phone            String?
  businessName     String?
  roleOrIndustry   String?
  instagram        String?
  linkedin         String?
  website          String?
  city             String?
  contactSource    String?
  consentToEmail   Boolean   @default(false)
  unsubscribed     Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastRsvpAt       DateTime?
  lastSurveyAt     DateTime?

  rsvps            Rsvp[]
  emailLogs        EmailLog[]
  surveyResponses  SurveyResponse[]
  notes            ContactNote[]
  tags             ContactTag[]
  opportunities    Opportunity[]
  followupTasks    FollowupTask[]

  @@map("contacts")
}

model Event {
  id                String    @id @default(cuid())
  eventName         String
  eventSlug         String    @unique
  eventDate         DateTime
  startTime         String
  endTime           String
  locationName      String
  address           String
  description       String?
  rsvpLink          String?
  surveyLink        String?
  facebookEventLink String?
  status            String    @default("draft")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  rsvps             Rsvp[]
  emailLogs         EmailLog[]
  surveyResponses   SurveyResponse[]
  opportunities     Opportunity[]
  walkIns           WalkIn[]
  followupTasks     FollowupTask[]
  promoTasks        PromoTask[]
  localOutreach     LocalOutreach[]

  @@map("events")
}

model Rsvp {
  id              String    @id @default(cuid())
  contactId       String
  eventId         String
  rsvpStatus      String    @default("confirmed")
  numberOfGuests  Int       @default(1)
  howDidYouHear   String?
  checkedIn       Boolean   @default(false)
  attended        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contact         Contact   @relation(fields: [contactId], references: [id])
  event           Event     @relation(fields: [eventId], references: [id])

  @@unique([contactId, eventId])
  @@map("rsvps")
}

model SurveyResponse {
  id                String    @id @default(cuid())
  contactId         String
  eventId           String?
  surveyTitle       String
  answersJson       Json
  rating            Int?
  interestTags      String[]
  keyFeedback       String?
  suggestedFollowUp String?
  submittedAt       DateTime  @default(now())

  contact           Contact   @relation(fields: [contactId], references: [id])
  event             Event?    @relation(fields: [eventId], references: [id])

  @@map("survey_responses")
}

model EmailLog {
  id            String    @id @default(cuid())
  contactId     String
  eventId       String?
  emailType     String
  subject       String
  status        String    @default("sent")
  sentAt        DateTime  @default(now())
  openedAt      DateTime?
  clickedAt     DateTime?
  errorMessage  String?

  contact       Contact   @relation(fields: [contactId], references: [id])
  event         Event?    @relation(fields: [eventId], references: [id])

  @@map("email_logs")
}

model ContactNote {
  id          String   @id @default(cuid())
  contactId   String
  note        String
  createdBy   String
  createdAt   DateTime @default(now())

  contact     Contact  @relation(fields: [contactId], references: [id])

  @@map("contact_notes")
}

model ContactTag {
  id        String  @id @default(cuid())
  contactId String
  tag       String

  contact   Contact @relation(fields: [contactId], references: [id])

  @@unique([contactId, tag])
  @@map("contact_tags")
}

model Opportunity {
  id              String    @id @default(cuid())
  contactId       String
  eventId         String?
  opportunityType String
  status          String    @default("potential")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contact         Contact   @relation(fields: [contactId], references: [id])
  event           Event?    @relation(fields: [eventId], references: [id])

  @@map("opportunities")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  @@map("admin_users")
}

// ─── Member app (client-facing) ─────────────────────────────────────────────

model Member {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  firstName      String
  lastName       String?
  fullName       String
  businessName   String?
  roleOrIndustry String?
  city           String?
  instagram      String?
  website        String?
  bio            String?
  avatarUrl      String?
  contactId      String?  // links to the CRM Contact record
  status         String   @default("active") // active | pending | suspended — lets us switch to approval later
  role           String   @default("member")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastSeenAt     DateTime?

  posts             Post[]
  comments          PostComment[]
  likes             PostLike[]
  pushSubscriptions PushSubscription[]

  @@map("members")
}

model Post {
  id        String   @id @default(cuid())
  memberId  String
  body      String
  imageUrl  String?
  kind      String   @default("update") // update | ask | offer
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member   Member        @relation(fields: [memberId], references: [id])
  comments PostComment[]
  likes    PostLike[]

  @@map("posts")
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  memberId  String
  body      String
  createdAt DateTime @default(now())

  post   Post   @relation(fields: [postId], references: [id])
  member Member @relation(fields: [memberId], references: [id])

  @@map("post_comments")
}

model PostLike {
  id       String @id @default(cuid())
  postId   String
  memberId String

  post   Post   @relation(fields: [postId], references: [id])
  member Member @relation(fields: [memberId], references: [id])

  @@unique([postId, memberId])
  @@map("post_likes")
}

model Update {
  id          String   @id @default(cuid())
  title       String
  body        String
  category    String   @default("ai") // ai | growth | event | announcement
  link        String?
  imageUrl    String?
  pinned      Boolean  @default(false)
  published   Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("updates")
}

model PushSubscription {
  id        String   @id @default(cuid())
  memberId  String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  member Member? @relation(fields: [memberId], references: [id])

  @@map("push_subscriptions")
}

model EmailCampaign {
  id          String    @id @default(cuid())
  name        String
  subject     String
  bodyHtml    String
  audienceTag String?
  eventId     String?
  status      String    @default("draft")
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("email_campaigns")
}

model NewsletterSignup {
  id          String   @id @default(cuid())
  email       String   @unique
  firstName   String?
  lastName    String?
  source      String?
  createdAt   DateTime @default(now())

  @@map("newsletter_signups")
}

model ContactSubmission {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String
  phone       String?
  message     String
  subject     String?
  source      String?
  createdAt   DateTime @default(now())

  @@map("contact_submissions")
}

model SponsorInquiry {
  id              String   @id @default(cuid())
  companyName     String
  contactName     String
  email           String
  phone           String?
  website         String?
  sponsorshipType String?
  budget          String?
  message         String?
  status          String   @default("new")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("sponsor_inquiries")
}

model WalkIn {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String?
  businessName  String?
  instagram     String?
  eventId       String?
  notes         String?
  createdAt     DateTime @default(now())

  event         Event?   @relation(fields: [eventId], references: [id])

  @@map("walk_ins")
}

model FollowupTask {
  id          String   @id @default(cuid())
  contactId   String?
  eventId     String?
  title       String
  notes       String?
  dueDate     DateTime?
  assignedTo  String?
  status      String   @default("pending")
  priority    String   @default("normal")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact     Contact? @relation(fields: [contactId], references: [id])
  event       Event?   @relation(fields: [eventId], references: [id])

  @@map("followup_tasks")
}

model PromoTask {
  id          String   @id @default(cuid())
  eventId     String?
  platform    String
  contentType String
  description String
  dueDate     DateTime?
  assignedTo  String?
  status      String   @default("pending")
  postUrl     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event?   @relation(fields: [eventId], references: [id])

  @@map("promo_tasks")
}

model LocalOutreach {
  id            String   @id @default(cuid())
  businessName  String
  contactName   String?
  email         String?
  phone         String?
  address       String?
  neighborhood  String?
  outreachType  String?
  status        String   @default("not_contacted")
  notes         String?
  lastContactAt DateTime?
  eventId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event         Event?   @relation(fields: [eventId], references: [id])

  @@map("local_outreach")
}

model SocialConnection {
  id              String    @id @default(cuid())
  platform        String
  pageId          String?
  pageName        String?
  pageAccessToken String?
  igBusinessId    String?
  igUsername      String?
  connectedAt     DateTime  @default(now())
  expiresAt       DateTime?
  connectedBy     String?

  @@map("social_connections")
}

model SocialPost {
  id             String    @id @default(cuid())
  platform       String
  message        String?
  imageUrl       String?
  status         String    @default("pending")
  externalPostId String?
  permalink      String?
  errorMessage   String?
  createdAt      DateTime  @default(now())
  postedAt       DateTime?

  @@map("social_posts")
}
